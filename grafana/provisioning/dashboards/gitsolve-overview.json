{
  "uid": "gitsolve-overview",
  "title": "GitSolve AI — Overview",
  "tags": ["gitsolve"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Issues Attempted",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "increase(gitsolve_issues_attempted_total[1h])",
        "legendFormat": "attempted"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Issues Succeeded",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "increase(gitsolve_issues_succeeded_total[1h])",
        "legendFormat": "succeeded"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Issues Failed",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "increase(gitsolve_issues_failed_total[1h])",
        "legendFormat": "failed"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }] } } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg Iterations per Fix",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "rate(gitsolve_fix_iterations_sum[1h]) / rate(gitsolve_fix_iterations_count[1h])",
        "legendFormat": "avg iterations"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "decimals": 1 } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Issue Outcomes Over Time",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(gitsolve_issues_succeeded_total[5m])",
          "legendFormat": "succeeded"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(gitsolve_issues_failed_total[5m])",
          "legendFormat": "failed"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "succeeded" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Triage Duration (p95)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "histogram_quantile(0.95, rate(gitsolve_triage_duration_seconds_bucket[5m]))",
        "legendFormat": "p95 triage"
      }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "JVM Memory Used",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "jvm_memory_used_bytes{application=\"gitsolve-ai\"}",
        "legendFormat": "{{area}} {{id}}"
      }],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "rate(http_server_requests_seconds_count{application=\"gitsolve-ai\"}[1m])",
        "legendFormat": "{{method}} {{uri}} {{status}}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ]
}
