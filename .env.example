# .env.example — GitSolve AI configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.

# ── Required ─────────────────────────────────────────────────────────────────

# GitHub personal access token (classic) with the following scopes:
#   - repo (read)
#   - read:org
# Generate at: https://github.com/settings/tokens
GITHUB_APP_TOKEN=ghp_your_github_personal_access_token_here

# Anthropic API key for Claude (Haiku + Sonnet models).
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# ── Database ──────────────────────────────────────────────────────────────────

# JDBC URL for PostgreSQL.
# Default docker-compose setup: jdbc:postgresql://localhost:5433/gitsolve
# (port 5433 to avoid colliding with a local Postgres on the default port)
DATABASE_URL=jdbc:postgresql://localhost:5433/gitsolve

# PostgreSQL credentials (must match docker-compose.yml or your own Postgres instance)
DATABASE_USER=gitsolve
DATABASE_PASSWORD=change-me-in-production

# ── Observability (optional) ──────────────────────────────────────────────────

# Grafana admin password (used by docker-compose.yml).
# Default is "admin" — change this for any non-local deployment.
GRAFANA_ADMIN_PASSWORD=change-me

# OpenTelemetry OTLP exporter endpoint (optional).
# Used when gitsolve.telemetry.enabled=true (or OTEL_EXPORTER_OTLP_ENDPOINT is set).
# Points to your local or remote OTEL collector.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# ── Optional ──────────────────────────────────────────────────────────────────

# Google Gemini API key — only required when gitsolve.llm.provider=gemini.
# The default provider is "anthropic"; leave this blank unless you switch providers.
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
